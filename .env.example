# ── Domain ──────────────────────────────────────────────────────────────────
DOMAIN=vpn.example.com

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
DB_PASSWORD=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Xray ─────────────────────────────────────────────────────────────────────
XRAY_API_ADDR=xray:8080
# Generated by install.sh via: docker run --rm teddysun/xray xray x25519
REALITY_PRIVATE_KEY=
REALITY_SHORT_ID=
# Public key — share this with VLESS clients (generated by install.sh)
REALITY_PUBLIC_KEY=

# ── Superadmin ───────────────────────────────────────────────────────────────
SUPERADMIN_LOGIN=admin
SUPERADMIN_PASSWORD=
